# ============================================
# GenLayer Event Alarm - Environment Variables
# ============================================
# Copy this file to .env and update the values

# Database URL (SQLite)
DATABASE_URL=file:./db/custom.db

# ============================================
# SECURITY CONFIGURATION - IMPORTANT!
# ============================================
# These are SERVER-SIDE only environment variables
# They are NOT exposed to the client-side code
# NEVER use NEXT_PUBLIC_ prefix for these!

# Admin password for admin panel access
# Generate a secure password: openssl rand -base64 24
ADMIN_PASSWORD=your-secure-password-here

# Secret key for URL-based admin access (format: ?admin=YOUR_KEY)
# Generate a secure key: openssl rand -hex 16
ADMIN_SECRET_KEY=your-secret-key-here

# ============================================
# HOW TO GENERATE SECURE CREDENTIALS
# ============================================
# Run these commands in your terminal:
#
# Password: openssl rand -base64 24
# Secret:   openssl rand -hex 16
#
# ============================================
# DEPLOYMENT NOTES (Vercel)
# ============================================
# When deploying to Vercel:
# 1. Go to Project Settings > Environment Variables
# 2. Add ADMIN_PASSWORD and ADMIN_SECRET_KEY
# 3. Make sure to NOT use NEXT_PUBLIC_ prefix
# 4. Use different values for Production vs Preview environments
